# RIVE .gitignore

# Data directories (large files)
data/

# MLflow local storage
mlruns/

# Environment variables
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Parquet files
*.parquet

# Jupyter checkpoints
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Working directories
visuals/

# Manuscript source (submitted separately)
paper.tex
final_report.tex

# Claude Code
.claude/
